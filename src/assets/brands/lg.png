nt/uploads/2025/06/car-5.webp" type="image/webp"><img data-lazyloaded="1" src="data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI2MDIiIGhlaWdodD0iODUxIiB2aWV3Qm94PSIwIDAgNjAyIDg1MSI+PHJlY3Qgd2lkdGg9IjEwMCUiIGhlaWdodD0iMTAwJSIgc3R5bGU9ImZpbGw6I2NmZDRkYjtmaWxsLW9wYWNpdHk6IDAuMTsiLz48L3N2Zz4=" width="602" height="851" data-src="https://goxxii.com/wp-content/uploads/2025/06/car-5.png" class="sp-no-webp swiper-slide-image sp-no-webp" alt="two people waving from the truck" decoding="async"></picture></figure></div></div><div class="elementor-swiper-button elementor-swiper-button-prev" role="button" tabindex="0"><svg xmlns="http://www.w3.org/2000/svg" width="60" height="18" viewbox="0 0 60 18" fill="none"><path d="M0 9L14.3697 0V7.75H60V10.25H14.3697V18L0 9Z" fill="#027DFA"></path></svg></div><div class="elementor-swiper-button elementor-swiper-button-next" role="button" tabindex="0"><svg xmlns="http://www.w3.org/2000/svg" width="60" height="18" viewbox="0 0 60 18" fill="none"><path d="M60 9L45.6303 0V7.75H0V10.25H45.6303V18L60 9Z" fill="#027DFA"></path></svg></div></div></div></div></div><div class="elementor-element elementor-element-45f8c30 e-con-full e-flex e-con e-child" data-id="45f8c30" data-element_type="container"><div class="elementor-element elementor-element-0cc14fd elementor-widget elementor-widget-heading" data-id="0cc14fd" data-element_type="widget" data-widget_type="heading.default"><div class="elementor-widget-container"><h2 class="elementor-heading-title elementor-size-default"><span style="color:#0078ff">XXII Century</span> -  Built Around Truck Drivers, Backed by Trust</h2></div></div><div class="elementor-element elementor-element-c949289 elementor-widget elementor-widget-text-editor" data-id="c949289" data-element_type="widget" data-widget_type="text-editor.default"><div class="elementor-widget-container"><p data-start="245" data-end="551">With over 15 years in the industry, XXII Century understands what matters most to drivers&mdash;<strong data-start="335" data-end="392">steady freight, real support, and respect on the road</strong>. Based in Chicago, we work closely with both <strong data-start="438" data-end="481">CDL company drivers and owner-operators</strong>, offering flexible opportunities that match your goals and lifestyle.</p><p data-start="553" data-end="801">For <strong data-start="557" data-end="576">owner-operators</strong>, we provide a reliable freight network, fast settlements, and the freedom to run your business with confidence—<strong data-start="688" data-end="713">without the headaches</strong>. Company drivers benefit from dedicated support, competitive pay, and consistent miles.</p><p data-start="803" data-end="1033">Whether you&rsquo;re running local, regional, or long-haul routes, our team is here 24/7 to keep you moving. At XXII Century, you can expect <strong data-start="938" data-end="1032">clear communication, fair treatment, and a team that truly works with you&mdash;not just for you</strong>.</p></div></div><div class="elementor-element elementor-element-fdb159d centuary-btn-cls elementor-mobile-align-center elementor-widget elementor-widget-button" data-id="fdb159d" data-element_type="widget" data-widget_type="button.default"><div class="elementor-widget-container"><div class="elementor-button-wrapper"><a class="elementor-button elementor-button-link elementor-size-sm" href="https://goxxii.com/about-us/"><span class="elementor-button-content-wrapper"><span class="elementor-button-icon"><svg aria-hidden="true" class="e-font-icon-svg e-fas-angle-double-right" viewbox="0 0 448 512" xmlns="http://www.w3.org/2000/svg"><path d="M224.3 273l-136 136c-9.4 9.4-24.6 9.4-33.9 0l-22.6-22.6c-9.4-9.4-9.4-24.6 0-33.9l96.4-96.4-96.4-96.4c-9.4-9.4-9.4-24.6 0-33.9L54.3 103c9.4-9.4 24.6-9.4 33.9 0l136 136c9.5 9.4 9.5 24.6.1 34zm192-34l-136-136c-9.4-9.4-24.6-9.4-33.9 0l-22.6 22.6c-9.4 9.4-9.4 24.6 0 33.9l96.4 96.4-96.4 96.4c-9.4 9.4-9.4 24.6 0 33.9l22.6 22.6c9